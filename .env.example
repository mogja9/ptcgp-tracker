# Optional. The public Limitless TCG endpoints used by this project work
# without a key, but they're rate-limited to 50 requests per 5 minutes.
#
# If you want a higher quota:
#   1. Apply at https://play.limitlesstcg.com/account/settings/api
#   2. Put the key here as LIMITLESS_API_KEY=...
#   3. The sync script will send it on every request automatically.
#
# Never commit this value. .env is in .gitignore.
LIMITLESS_API_KEY=
